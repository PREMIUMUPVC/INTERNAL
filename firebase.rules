rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // =========================================================================
    // HELPER FUNCTIONS
    // =========================================================================
    
    // Checks if the user is the Master Admin (via their Google Auth token)
    function isMasterAdmin() {
      // IMPORTANT: Replace this email with your actual Master Admin email account
      return request.auth != null && request.auth.token.email == "Kolatapuk.k@gmail.com";
    }
    
    // Checks if the user has been granted 'admin' role in the database
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Checks if the user is a standard approved employee
    function isApproved() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    // Security Check: Detects if someone is trying to sneak "role: 'admin'" into an update/create request
    function isTryingToMakeAdmin() {
      return request.resource.data.get('role', '') == 'admin' && 
             (resource == null || resource.data.get('role', '') != 'admin');
    }


    // =========================================================================
    // USERS COLLECTION
    // =========================================================================
    match /users/{userId} {
      // Anyone logged in can read user profiles
      allow read: if request.auth != null;
      
      // Users can create their own pending profile upon first login.
      // They are explicitly blocked from setting their role to 'admin'.
      allow create: if request.auth.uid == userId && !isTryingToMakeAdmin();
      
      // Update Permissions:
      // 1. Master Admin can update anything (including assigning Co-Admins).
      // 2. Co-Admins can update user docs (like approving employees), but CANNOT assign 'admin' role.
      // 3. Regular users can only update their own profile, but CANNOT change their 'role' or 'status'.
      allow update: if isMasterAdmin() 
                    || (isAdmin() && !isTryingToMakeAdmin()) 
                    || (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status']));
    }

    // =========================================================================
    // EMPLOYEES COLLECTION
    // =========================================================================
    match /employees/{employeeId} {
      // Master Admin and Co-Admins have full access
      allow read, write, delete: if isMasterAdmin() || isAdmin();
      
      // Approved employees can only read their own specific employee record
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.employeeId == employeeId;
      
      // --- Employee Sub-collections (Attendance and Payments) ---
      match /{subcollection}/{docId} {
        allow read, write, delete: if isMasterAdmin() || isAdmin();
        allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.employeeId == employeeId;
      }
    }
    
    // =========================================================================
    // ORDERS COLLECTION
    // =========================================================================
    match /upvc_orders/{orderId} {
      // Any approved employee, Co-Admin, or Master Admin can read, create, and update orders
      allow read, update, create: if isApproved() || isMasterAdmin() || isAdmin();
      
      // ONLY Admins (Master or Co-Admin) can delete an order
      allow delete: if isMasterAdmin() || isAdmin();
      
      // --- Order History Sub-collection ---
      // History entries can be read and created by authorized users, but NEVER edited or deleted (Immutable log)
      match /history/{historyId} {
        allow read, create: if isApproved() || isMasterAdmin() || isAdmin();
        allow update, delete: if false; 
      }
      
      // --- Order Payments Sub-collection ---
      match /payments/{paymentId} {
        // Any approved user can read order payments
        allow read: if isApproved() || isMasterAdmin() || isAdmin();
        
        // ONLY Admins (Master or Co-Admin) can create, update, or delete order payments
        allow create, update, delete: if isMasterAdmin() || isAdmin();
      }
    }
    
  }
}
