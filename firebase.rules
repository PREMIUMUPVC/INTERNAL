rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // --- EXISTING RULES ---
    
    // Users can create their own profile upon first login.
    // Any authenticated user can read any user's public profile data (displayName, photoURL).
    // Only the user themselves or an admin can update their profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Admins can read, write, and delete any employee document.
    // Approved employees can read their own employee document.
    match /employees/{employeeId} {
      allow read, write, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.employeeId == employeeId;
      
      // Sub-collections for Attendance and Payments
      match /{subcollection}/{docId} {
        allow read, write, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
        allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.employeeId == employeeId;
      }
    }
    
    // --- RULES FOR THE ORDER FORM & PAYMENTS ---
    
    // Any authenticated and 'approved' user can read, create, and update orders.
    match /upvc_orders/{orderId} {
      allow read, update, create: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
      // Only an admin can delete an order.
      allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // History sub-collection: only allow creating new history entries, no editing or deleting.
      match /history/{historyId} {
        allow read, create: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
        allow update, delete: if false; // History should be immutable
      }
      
      // *** NEW RULE FOR PAYMENT MANAGEMENT ***
      // Any approved user can read payments for an order.
      // ONLY an admin can create, update, or delete payments.
      match /payments/{paymentId} {
        allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
        allow create, update, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
    }
  }
}
